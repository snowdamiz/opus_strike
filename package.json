{
  "name": "voxel-strike",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:all": "pnpm db:up && pnpm db:migrate && concurrently -n db,redis,server,client -c magenta,yellow,green,cyan \"docker compose logs -f postgres\" \"docker compose logs -f redis\" \"pnpm dev:server\" \"pnpm dev:client\"",
    "build": "turbo run build",
    "build:client": "turbo run build --filter=@voxel-strike/client",
    "build:server": "turbo run build --filter=@voxel-strike/server",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test:voice": "pnpm --filter @voxel-strike/server test:voice && pnpm --filter @voxel-strike/client test:voice",
    "test:rank": "pnpm --filter @voxel-strike/shared test:rank",
    "test:ranking": "pnpm --filter @voxel-strike/server test:ranking",
    "test:wager": "pnpm --filter @voxel-strike/server test:wager",
    "test:authority": "pnpm --filter @voxel-strike/server test:authority",
    "test:movement": "pnpm --filter @voxel-strike/physics test:movement",
    "smoke:procedural-buildings": "pnpm --filter @voxel-strike/shared smoke:buildings",
    "clean": "turbo run clean",
    "db:up": "docker compose up -d --wait postgres redis",
    "db:down": "docker compose down",
    "db:generate": "pnpm --filter @voxel-strike/server db:generate",
    "db:migrate": "pnpm --filter @voxel-strike/server db:migrate",
    "db:push": "pnpm --filter @voxel-strike/server db:push",
    "dev:client": "turbo run dev --filter=@voxel-strike/client",
    "dev:server": "turbo run dev --filter=@voxel-strike/server",
    "dev:server:distributed:a": "COLYSEUS_DISTRIBUTED=1 COLYSEUS_REDIS_URL=redis://localhost:6379 PORT=2567 COLYSEUS_PUBLIC_ADDRESS=localhost:2567 pnpm dev:server",
    "dev:server:distributed:b": "COLYSEUS_DISTRIBUTED=1 COLYSEUS_REDIS_URL=redis://localhost:6379 PORT=2568 COLYSEUS_PUBLIC_ADDRESS=localhost:2568 pnpm dev:server",
    "test:distributed": "pnpm --filter @voxel-strike/server test:distributed-runtime"
  },
  "devDependencies": {
    "concurrently": "10.0.3",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3"
  }
}
