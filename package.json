{
  "name": "voxel-strike",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm dev:all",
    "dev:all": "pnpm dev:server:cluster:up && concurrently -n servers,client -c cyan,blue \"pnpm dev:server:cluster:logs\" \"turbo run dev --filter=@voxel-strike/client\"",
    "build": "turbo run build",
    "build:client": "turbo run build --filter=@voxel-strike/client",
    "build:server": "turbo run build --filter=@voxel-strike/server",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test:voice": "pnpm --filter @voxel-strike/server test:voice && pnpm --filter @voxel-strike/client test:voice",
    "test:rank": "pnpm --filter @voxel-strike/shared test:rank",
    "test:ranking": "pnpm --filter @voxel-strike/server test:ranking",
    "test:wager": "pnpm --filter @voxel-strike/server test:wager",
    "test:daily-missions": "pnpm --filter @voxel-strike/server test:daily-missions",
    "test:anticheat": "pnpm --filter @voxel-strike/server test:anticheat",
    "test:prelaunch:no-chain": "node scripts/run-prelaunch-no-spend.mjs",
    "test:movement-parity": "pnpm --filter @voxel-strike/server test:movement-parity",
    "test:movement-parity:full": "pnpm --filter @voxel-strike/server test:movement-parity:full",
    "test:autoscaler": "pnpm --filter @voxel-strike/server test:autoscaler",
    "test:authority": "pnpm --filter @voxel-strike/server test:authority",
    "test:movement": "pnpm --filter @voxel-strike/physics test:movement",
    "smoke:procedural-buildings": "pnpm --filter @voxel-strike/shared smoke:buildings",
    "clean": "turbo run clean",
    "stop:all": "node scripts/stop-all.mjs",
    "docker:ensure": "node scripts/ensure-docker.mjs",
    "db:up": "pnpm docker:ensure && docker compose up -d --wait postgres redis",
    "db:down": "docker compose down",
    "db:generate": "pnpm --filter @voxel-strike/server db:generate",
    "db:migrate": "pnpm --filter @voxel-strike/server db:migrate",
    "db:push": "pnpm --filter @voxel-strike/server db:push",
    "dev:client": "turbo run dev --filter=@voxel-strike/client",
    "dev:server": "pnpm dev:server:cluster:up && pnpm dev:server:cluster:logs",
    "dev:server:cluster:up": "pnpm docker:ensure && docker compose --profile server-cluster up -d --wait postgres redis && pnpm db:migrate && docker compose --profile server-cluster up -d --build --force-recreate --wait server-us-1 server-us-2 server-us-3 server-eu-1 server-asia-1",
    "dev:server:cluster:logs": "docker compose --profile server-cluster logs -f server-us-1 server-us-2 server-us-3 server-eu-1 server-asia-1",
    "dev:server:cluster:infra-logs": "docker compose --profile server-cluster logs -f postgres redis",
    "dev:server:local": "pnpm db:up && pnpm db:migrate && pnpm dev:server:runtime",
    "dev:server:runtime": "COLYSEUS_DISTRIBUTED=${COLYSEUS_DISTRIBUTED:-1} COLYSEUS_REDIS_URL=${COLYSEUS_REDIS_URL:-redis://localhost:${REDIS_PORT:-56379}} PREGENERATED_MAP_AUTO_TOP_UP_ENABLED=${PREGENERATED_MAP_AUTO_TOP_UP_ENABLED:-1} PREGENERATED_MAP_AUTO_TOP_UP_INITIAL_DELAY_MS=${PREGENERATED_MAP_AUTO_TOP_UP_INITIAL_DELAY_MS:-1000} PREGENERATED_MAP_AUTO_TOP_UP_INTERVAL_MS=${PREGENERATED_MAP_AUTO_TOP_UP_INTERVAL_MS:-5000} PREGENERATED_MAP_AUTO_TOP_UP_MAX_GENERATED_PER_RUN=${PREGENERATED_MAP_AUTO_TOP_UP_MAX_GENERATED_PER_RUN:-16} turbo run dev --filter=@voxel-strike/server",
    "test:distributed": "pnpm --filter @voxel-strike/server test:distributed-runtime",
    "verify:autoscaler-live": "pnpm --filter @voxel-strike/server verify:autoscaler-live",
    "simulate:autoscaler-demand": "pnpm --filter @voxel-strike/server simulate:autoscaler-demand"
  },
  "devDependencies": {
    "concurrently": "10.0.3",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3"
  }
}
