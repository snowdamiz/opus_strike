{
  "name": "@voxel-strike/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test:rank": "pnpm build && node scripts/ranking.test.mjs",
    "test:battle-royal": "pnpm build && node scripts/battle-royal-mode.test.mjs",
    "test:aegis": "pnpm build && node scripts/chronos-aegis-collision.test.mjs",
    "test:damage": "pnpm build && node scripts/damage-engine.test.mjs",
    "test:model-system": "pnpm build && node scripts/hero-skin-catalog.test.mjs",
    "test:model-sockets": "pnpm build && node scripts/ability-socket-catalog.test.mjs",
    "test:scrapshot": "pnpm build && node scripts/blaze-scrapshot.test.mjs",
    "test:phosphor-flare": "pnpm build && node scripts/blaze-phosphor-flare.test.mjs",
    "test:rift-bolt": "pnpm build && node scripts/phantom-rift-bolt.test.mjs",
    "test:nightreign": "pnpm build && node scripts/phantom-nightreign.test.mjs",
    "test:afterburner": "pnpm build && node scripts/blaze-afterburner.test.mjs",
    "test:maps": "pnpm build && node scripts/procedural-building-smoke.mjs --known",
    "smoke:buildings": "pnpm build && node scripts/procedural-building-smoke.mjs",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
