{
  "name": "@voxel-strike/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:og": "python3 scripts/generate-og-image.py",
    "build": "tsc && vite build",
    "analyze": "ANALYZE=true vite build",
    "lint": "pnpm lint:tokens",
    "lint:tokens": "node scripts/lint-design-tokens.mjs",
    "test:voice": "tsx src/store/voiceStore.test.ts && tsx src/components/ui/VoiceHud.test.ts",
    "test:visual-store": "tsx src/store/visualStore.test.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.14.0",
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "@solana/web3.js": "^1.95.4",
    "@voxel-strike/game-logic": "workspace:*",
    "@voxel-strike/physics": "workspace:*",
    "@voxel-strike/shared": "workspace:*",
    "bs58": "^6.0.0",
    "colyseus.js": "^0.15.25",
    "livekit-client": "2.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "tweetnacl": "^1.0.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.8.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "buffer": "^6.0.3",
    "postcss": "^8.4.47",
    "r3f-perf": "^7.2.3",
    "rollup-plugin-visualizer": "^5.12.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
