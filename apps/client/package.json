{
  "name": "@voxel-strike/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:og": "python3 scripts/generate-og-image.py",
    "build": "tsc && vite build",
    "analyze": "ANALYZE=true vite build",
    "lint": "pnpm lint:tokens",
    "lint:tokens": "node scripts/lint-design-tokens.mjs",
    "test:voice": "tsx src/store/voiceStore.test.ts && tsx src/components/ui/VoiceHud.test.ts",
    "test:movement": "tsx src/movement/localPrediction.test.ts && tsx src/hooks/player/useCamera.test.ts && tsx src/hooks/player/abilityAim.test.ts && tsx src/components/game/PlayerController.frame.test.ts",
    "test:player-frame": "tsx src/components/game/PlayerController.frame.test.ts",
    "test:visual-store": "tsx src/store/visualStore.test.ts && tsx src/store/gameTimingStore.test.ts && tsx src/store/projectileSlicePerformance.test.ts && tsx src/components/game/performanceUtils.test.ts && tsx src/components/game/RemoteMovementEffects.test.ts && tsx src/components/game/playerWorldAnchors.test.ts && tsx src/components/game/brVisibilityConfig.test.ts",
    "test:map-warmup": "tsx src/utils/mapWarmup/mapPrepCache.test.ts && tsx src/utils/mapWarmup/mapGeometryWarmup.test.ts",
    "bench:br-combat-canvas": "tsx src/scripts/br-combat-canvas-benchmark.ts",
    "bench:br-geometry-hydration": "tsx src/scripts/br-geometry-hydration-benchmark.ts",
    "bench:br-map-render": "tsx src/scripts/br-map-render-budget-benchmark.ts",
    "test:party-store": "tsx src/store/partyStore.test.ts",
    "test:model-system": "tsx src/model-system/heroModelSystem.test.ts",
    "test:terrain-textures": "tsx src/components/game/procedural/proceduralTerrainTexturePlan.test.ts && tsx src/components/game/procedural/meshBuilderFinalizationQueue.test.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.14.0",
    "@preact/signals-react": "3.10.1",
    "@radix-ui/react-select": "2.3.0",
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "@solana/web3.js": "^1.95.4",
    "@voxel-strike/physics": "workspace:*",
    "@voxel-strike/shared": "workspace:*",
    "bs58": "^6.0.0",
    "colyseus.js": "^0.15.25",
    "livekit-client": "2.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "tweetnacl": "^1.0.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.8.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "buffer": "^6.0.3",
    "postcss": "^8.4.47",
    "rollup-plugin-visualizer": "^5.12.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
