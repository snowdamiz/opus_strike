{
  "name": "@voxel-strike/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test:auth": "tsx src/scripts/auth-service.test.ts",
    "test:authority": "tsx src/scripts/authority-hardening-harness.ts",
    "test:persistence": "tsx src/scripts/match-persistence.test.ts",
    "test:voice": "tsx src/scripts/voice-service.test.ts",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@colyseus/schema": "^2.0.0",
    "@colyseus/ws-transport": "^0.15.0",
    "@dimforge/rapier3d-compat": "^0.14.0",
    "@prisma/client": "^5.22.0",
    "@solana/web3.js": "^1.95.4",
    "@voxel-strike/game-logic": "workspace:*",
    "@voxel-strike/physics": "workspace:*",
    "@voxel-strike/shared": "workspace:*",
    "bs58": "^6.0.0",
    "colyseus": "^0.15.55",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "2.15.4",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.8.4",
    "prisma": "^5.22.0",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3"
  }
}
