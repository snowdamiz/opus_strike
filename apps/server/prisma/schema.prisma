// Prisma schema for Slop Heroes
// PostgreSQL database for user persistence

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  discord
  phantom
}

enum MatchMode {
  quick_play
  ranked
  custom
  custom_wager
}

enum WageredLobbyStatus {
  waiting
  locked
  in_game
  review_required
  settling
  settled
  refunding
  refunded
  failed
}

enum WagerPaymentStatus {
  intent_created
  submitted
  confirmed
  credited
  refunding
  refunded
  settled
  failed
  expired
}

enum WagerSettlementStatus {
  pending
  processing
  complete
  failed
}

enum WagerSettlementTransferKind {
  winner_payout
  developer_fee
  refund
}

enum WagerSettlementTransferStatus {
  pending
  submitted
  confirmed
  failed
}

enum GoldenBiomeRewardStatus {
  pending
  processing
  complete
  failed
}

enum GoldenBiomeRewardTransferStatus {
  pending
  submitted
  confirmed
  failed
}

enum GoldenBiomeRewardDistributionMode {
  manual
  auto
}

enum RankedSeasonMode {
  preseason
  season
}

enum FriendshipStatus {
  pending
  accepted
  declined
  canceled
}

enum LobbyInviteStatus {
  pending
  accepted
  declined
  canceled
  expired
}

enum PartyInviteStatus {
  pending
  accepted
  declined
  canceled
  expired
}

model User {
  id                     String                  @id @default(cuid())
  walletAddress          String?                 @unique
  // Callsigns are unique case-insensitively via the User_name_lower_key index.
  name                   String                  @unique
  lastLoginAt            DateTime?
  tutorialCompletedAt    DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  authAccounts           AuthAccount[]
  matchStats             GameMatchParticipant[]
  wageredLobbies         WageredLobby[]
  wagerPayments          WagerPayment[]
  rankedEntryQuotes      RankedEntryQuote[]
  rankedSeasonStats      RankedSeasonUserStats[]
  friendshipsA           Friendship[]            @relation("FriendshipUserA")
  friendshipsB           Friendship[]            @relation("FriendshipUserB")
  friendshipRequestsSent Friendship[]            @relation("FriendshipRequester")
  sentLobbyInvites       LobbyInvite[]           @relation("LobbyInviteSender")
  receivedLobbyInvites   LobbyInvite[]           @relation("LobbyInviteRecipient")
  sentPartyInvites       PartyInvite[]           @relation("PartyInviteSender")
  receivedPartyInvites   PartyInvite[]           @relation("PartyInviteRecipient")

  // Player stats (optional - can expand later)
  totalGames                Int       @default(0)
  totalWins                 Int       @default(0)
  totalLosses               Int       @default(0)
  totalDraws                Int       @default(0)
  totalKills                Int       @default(0)
  totalDeaths               Int       @default(0)
  totalAssists              Int       @default(0)
  totalCaptures             Int       @default(0)
  totalFlagReturns          Int       @default(0)
  totalScore                Int       @default(0)
  totalExperience           Int       @default(0)
  totalWagerGames           Int       @default(0)
  totalWagerWins            Int       @default(0)
  totalWagerLosses          Int       @default(0)
  totalWagerDraws           Int       @default(0)
  totalWageredLamports      BigInt    @default(0)
  totalWagerWonLamports     BigInt    @default(0)
  totalWagerLostLamports    BigInt    @default(0)
  competitiveRating         Int       @default(800)
  rankedGames               Int       @default(0)
  rankedWins                Int       @default(0)
  rankedLosses              Int       @default(0)
  rankedDraws               Int       @default(0)
  rankedPlacementsRemaining Int       @default(0)
  rankedPeakRating          Int       @default(800)
  rankedLastMatchAt         DateTime?

  @@index([walletAddress])
  @@index([competitiveRating(sort: Desc), rankedWins(sort: Desc), rankedGames, createdAt])
}

model AuthAccount {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  displayName       String?
  avatarUrl         String?
  emailHash         String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Friendship {
  id                String           @id @default(cuid())
  userAId           String
  userBId           String
  requestedByUserId String
  status            FriendshipStatus @default(pending)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  respondedAt       DateTime?

  userA       User @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB       User @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)
  requestedBy User @relation("FriendshipRequester", fields: [requestedByUserId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId, status])
  @@index([userBId, status])
  @@index([requestedByUserId, status])
  @@index([status, updatedAt])
}

model LobbyInvite {
  id          String            @id @default(cuid())
  lobbyId     String
  lobbyName   String
  matchMode   MatchMode?
  fromUserId  String
  toUserId    String
  status      LobbyInviteStatus @default(pending)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  expiresAt   DateTime
  respondedAt DateTime?

  fromUser User @relation("LobbyInviteSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("LobbyInviteRecipient", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId, status, createdAt])
  @@index([fromUserId, createdAt])
  @@index([lobbyId, status])
  @@index([expiresAt])
}

model PartyInvite {
  id          String            @id @default(cuid())
  partyId     String
  fromUserId  String
  toUserId    String
  status      PartyInviteStatus @default(pending)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  expiresAt   DateTime
  respondedAt DateTime?

  fromUser User @relation("PartyInviteSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("PartyInviteRecipient", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId, status, createdAt])
  @@index([fromUserId, createdAt])
  @@index([partyId, status])
  @@index([expiresAt])
}

model PersistentParty {
  id             String   @id
  roomId         String   @unique
  ownerUserId    String
  leaderUserId   String?
  allowedUserIds String[] @default([])
  snapshot       Json
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([ownerUserId, updatedAt])
  @@index([expiresAt])
}

model GameMatch {
  id                       String    @id
  roomId                   String
  lobbyId                  String?
  matchMode                MatchMode @default(custom)
  mapSeed                  Int
  mapThemeId               String    @default("standard")
  startedAt                DateTime
  endedAt                  DateTime
  redScore                 Int
  blueScore                Int
  winningTeam              String?
  rankedEligible           Boolean   @default(false)
  antiCheatIntegrityStatus String    @default("clean")
  antiCheatReviewRequired  Boolean   @default(false)
  antiCheatIntegrityReason String?
  rankedOutcomeStatus      String    @default("not_applicable")
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  participants GameMatchParticipant[]

  @@index([roomId])
  @@index([lobbyId])
  @@index([matchMode])
  @@index([mapThemeId])
  @@index([startedAt])
  @@index([winningTeam])
  @@index([rankedEligible])
  @@index([antiCheatIntegrityStatus])
  @@index([antiCheatReviewRequired])
  @@index([rankedOutcomeStatus])
}

model GameMatchParticipant {
  id                   String    @id @default(cuid())
  matchId              String
  userId               String
  playerSessionId      String
  displayName          String
  team                 String
  heroId               String?
  kills                Int       @default(0)
  deaths               Int       @default(0)
  assists              Int       @default(0)
  flagCaptures         Int       @default(0)
  flagReturns          Int       @default(0)
  score                Int       @default(0)
  experienceGained     Int       @default(0)
  outcome              String
  rankedEligible       Boolean   @default(false)
  ratingBefore         Int?
  ratingAfter          Int?
  ratingDelta          Int?
  visibleRankBefore    String?
  visibleRankAfter     String?
  leaverPenaltyApplied Boolean   @default(false)
  joinedAt             DateTime
  leftAt               DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  match GameMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([matchId])
  @@index([userId, joinedAt])
  @@index([outcome])
  @@index([rankedEligible])
  @@index([userId, rankedEligible, joinedAt])
}

model RankedEntryQuote {
  id                  String   @id @default(cuid())
  userId              String
  usdCents            Int
  solUsdPriceMicroUsd BigInt
  coverChargeLamports BigInt
  priceSource         String
  cluster             String
  createdAt           DateTime @default(now())
  expiresAt           DateTime

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  wageredLobbies WageredLobby[]
  wagerPayments  WagerPayment[]

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@index([coverChargeLamports])
}

model WageredLobby {
  id                  String             @id @default(cuid())
  lobbyId             String             @unique
  gameRoomId          String?
  matchId             String?
  matchMode           MatchMode          @default(custom_wager)
  rankedEntryQuoteId  String?
  status              WageredLobbyStatus @default(waiting)
  token               String             @default("SOL")
  coverChargeLamports BigInt
  treasuryWallet      String
  platformFeeBps      Int                @default(500)
  createdByUserId     String
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  lockedAt            DateTime?
  settledAt           DateTime?

  createdBy        User              @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  rankedEntryQuote RankedEntryQuote? @relation(fields: [rankedEntryQuoteId], references: [id], onDelete: SetNull)
  payments         WagerPayment[]
  settlement       WagerSettlement?

  @@index([lobbyId])
  @@index([matchMode])
  @@index([rankedEntryQuoteId])
  @@index([gameRoomId])
  @@index([matchId])
  @@index([status])
  @@index([createdByUserId])
}

model WagerPayment {
  id                        String             @id
  wageredLobbyId            String
  lobbyPlayerId             String?
  userId                    String
  walletAddress             String
  rankedEntryQuoteId        String?
  teamAtLock                String?
  amountLamports            BigInt
  surplusLamports           BigInt             @default(0)
  memo                      String             @unique
  intentExpiresAt           DateTime
  status                    WagerPaymentStatus @default(intent_created)
  depositSignature          String?            @unique
  refundSignature           String?            @unique
  refundReason              String?
  refundGrossLamports       BigInt?
  refundOutboundFeeLamports BigInt?
  refundNetLamports         BigInt?
  refundFeeSource           String?
  lastError                 String?
  creditedAt                DateTime?
  refundedAt                DateTime?
  settledAt                 DateTime?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  wageredLobby     WageredLobby      @relation(fields: [wageredLobbyId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  rankedEntryQuote RankedEntryQuote? @relation(fields: [rankedEntryQuoteId], references: [id], onDelete: SetNull)

  @@unique([wageredLobbyId, userId])
  @@index([wageredLobbyId])
  @@index([userId])
  @@index([rankedEntryQuoteId])
  @@index([walletAddress])
  @@index([status])
  @@index([intentExpiresAt])
}

model WagerSettlement {
  id                   String                @id @default(cuid())
  wageredLobbyId       String                @unique
  matchId              String?
  winningTeam          String?
  totalPotLamports     BigInt                @default(0)
  developerFeeLamports BigInt                @default(0)
  winnerPoolLamports   BigInt                @default(0)
  status               WagerSettlementStatus @default(pending)
  attemptCount         Int                   @default(0)
  lastError            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  completedAt          DateTime?

  wageredLobby WageredLobby              @relation(fields: [wageredLobbyId], references: [id], onDelete: Cascade)
  transfers    WagerSettlementTransfer[]

  @@index([matchId])
  @@index([status])
}

model WagerSettlementTransfer {
  id                        String                        @id @default(cuid())
  settlementId              String
  idempotencyKey            String                        @unique
  kind                      WagerSettlementTransferKind
  recipientWallet           String
  amountLamports            BigInt
  signature                 String?                       @unique
  refundReason              String?
  refundGrossLamports       BigInt?
  refundOutboundFeeLamports BigInt?
  refundNetLamports         BigInt?
  refundFeeSource           String?
  status                    WagerSettlementTransferStatus @default(pending)
  lastError                 String?
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt
  confirmedAt               DateTime?

  settlement WagerSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@unique([settlementId, kind, recipientWallet])
  @@index([settlementId])
  @@index([kind])
  @@index([status])
}

model GoldenBiomeReward {
  id                      String                            @id @default(cuid())
  matchId                 String                            @unique
  roomId                  String
  lobbyId                 String?
  mapSeed                 Int
  mapThemeId              String                            @default("golden")
  winningTeam             String
  treasuryWallet          String
  rewardUsdCents          Int
  solUsdPriceMicroUsd     BigInt
  rewardLamports          BigInt
  totalRewardLamports     BigInt
  paidPlayerCount         Int
  treasuryBalanceLamports BigInt
  status                  GoldenBiomeRewardStatus           @default(pending)
  distributionMode        GoldenBiomeRewardDistributionMode @default(manual)
  distributedByUserId     String?
  distributedAt           DateTime?
  attemptCount            Int                               @default(0)
  lastError               String?
  createdAt               DateTime                          @default(now())
  updatedAt               DateTime                          @updatedAt
  completedAt             DateTime?

  transfers GoldenBiomeRewardTransfer[]

  @@index([roomId])
  @@index([lobbyId])
  @@index([status])
  @@index([distributionMode])
  @@index([createdAt])
}

model GoldenBiomeRewardSettings {
  id               String                            @id @default("default")
  distributionMode GoldenBiomeRewardDistributionMode @default(manual)
  updatedByUserId  String?
  createdAt        DateTime                          @default(now())
  updatedAt        DateTime                          @updatedAt
}

model RankedSeasonSettings {
  id              String           @id @default("default")
  mode            RankedSeasonMode @default(season)
  seasonNumber    Int              @default(1)
  endsAt          DateTime?
  lastResetAt     DateTime?
  updatedByUserId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model RankedSeasonUserStats {
  id                        String           @id @default(cuid())
  mode                      RankedSeasonMode @default(season)
  seasonNumber              Int
  userId                    String
  userName                  String
  totalGames                Int              @default(0)
  totalWins                 Int              @default(0)
  totalLosses               Int              @default(0)
  totalDraws                Int              @default(0)
  totalKills                Int              @default(0)
  totalDeaths               Int              @default(0)
  totalAssists              Int              @default(0)
  totalCaptures             Int              @default(0)
  totalFlagReturns          Int              @default(0)
  totalScore                Int              @default(0)
  totalExperience           Int              @default(0)
  competitiveRating         Int              @default(800)
  rankedGames               Int              @default(0)
  rankedWins                Int              @default(0)
  rankedLosses              Int              @default(0)
  rankedDraws               Int              @default(0)
  rankedPlacementsRemaining Int              @default(0)
  rankedPeakRating          Int              @default(800)
  rankedLastMatchAt         DateTime?
  archivedAt                DateTime?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mode, seasonNumber, userId])
  @@index([mode, seasonNumber, competitiveRating(sort: Desc), rankedWins(sort: Desc), rankedGames, updatedAt])
  @@index([userId, mode, seasonNumber])
}

model GlobalNotification {
  id              String   @id @default("active")
  message         String   @db.Text
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GoldenBiomeRewardTransfer {
  id              String                          @id @default(cuid())
  rewardId        String
  idempotencyKey  String                          @unique
  userId          String
  playerSessionId String
  recipientWallet String
  amountLamports  BigInt
  signature       String?                         @unique
  status          GoldenBiomeRewardTransferStatus @default(pending)
  lastError       String?
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @updatedAt
  confirmedAt     DateTime?

  reward GoldenBiomeReward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@unique([rewardId, recipientWallet])
  @@index([rewardId])
  @@index([userId])
  @@index([recipientWallet])
  @@index([status])
}

model AntiCheatSignal {
  id               String     @id @default(cuid())
  eventId          String     @unique
  eventType        String
  category         String
  source           String
  roomId           String
  matchId          String?
  lobbyId          String?
  matchMode        MatchMode?
  userId           String?
  playerSessionId  String?
  team             String?
  heroId           String?
  serverTick       Int
  serverTime       BigInt
  movementEpoch    Int?
  movementSequence Int?
  severity         String
  confidence       Float
  reason           String?
  details          Json
  detailBytes      Int
  retentionClass   String
  scoreDelta       Int        @default(0)
  observedAt       DateTime
  createdAt        DateTime   @default(now())

  @@index([eventType, observedAt])
  @@index([category, severity, observedAt])
  @@index([roomId, observedAt])
  @@index([matchId, observedAt])
  @@index([lobbyId, observedAt])
  @@index([userId, observedAt])
  @@index([playerSessionId, observedAt])
  @@index([retentionClass, observedAt])
}

model AntiCheatPlayerProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  currentScore Int       @default(0)
  maxScore     Int       @default(0)
  scoreBand    String    @default("normal_noise")
  reviewFlags  String[]  @default([])
  lastSignalAt DateTime?
  lastScoredAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([currentScore])
  @@index([scoreBand])
  @@index([lastSignalAt])
}

model AntiCheatMatchIntegrity {
  id               String    @id @default(cuid())
  matchId          String    @unique
  roomId           String
  lobbyId          String?
  matchMode        MatchMode
  status           String    @default("clean")
  reason           String?
  score            Int       @default(0)
  affectedUserIds  String[]  @default([])
  affectedTeams    String[]  @default([])
  rankedImpact     String    @default("none")
  wagerImpact      String    @default("none")
  caseId           String?
  resolvedByUserId String?
  resolvedAt       DateTime?
  resolution       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([roomId])
  @@index([lobbyId])
  @@index([matchMode, status])
  @@index([caseId])
}

model AntiCheatPayoutHold {
  id               String    @id @default(cuid())
  wageredLobbyId   String    @unique
  matchId          String?
  winningTeam      String?
  paymentIds       String[]  @default([])
  affectedUserIds  String[]  @default([])
  amountLamports   BigInt    @default(0)
  reason           String
  status           String    @default("open")
  caseId           String?
  resolvedByUserId String?
  resolvedAt       DateTime?
  resolution       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([matchId])
  @@index([status, createdAt])
  @@index([caseId])
}

model AntiCheatAction {
  id                 String   @id @default(cuid())
  actionType         String
  roomId             String?
  matchId            String?
  caseId             String?
  userId             String?
  actorUserId        String?
  reason             String
  details            Json
  observedOnly       Boolean  @default(false)
  evidenceEventIds   String[] @default([])
  reversedByActionId String?
  createdAt          DateTime @default(now())

  @@index([actionType, createdAt])
  @@index([matchId, createdAt])
  @@index([caseId, createdAt])
  @@index([userId, createdAt])
  @@index([actorUserId, createdAt])
}

model AntiCheatAccountAction {
  id               String    @id @default(cuid())
  actionType       String
  targetUserId     String
  actorUserId      String
  reason           String
  evidenceCaseId   String?
  evidenceEventIds String[]  @default([])
  expiresAt        DateTime?
  liftedAt         DateTime?
  immutableAudit   Boolean   @default(false)
  createdAt        DateTime  @default(now())

  @@index([targetUserId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([actionType, createdAt])
  @@index([evidenceCaseId])
  @@index([expiresAt])
}

model AntiCheatCase {
  id               String     @id @default(cuid())
  userId           String?
  playerSessionId  String?
  matchId          String?
  roomId           String?
  lobbyId          String?
  matchMode        MatchMode?
  status           String     @default("open")
  priority         String     @default("medium")
  reason           String
  scoreAtOpen      Int        @default(0)
  signalCount      Int        @default(0)
  evidenceEventIds String[]   @default([])
  assignedToUserId String?
  notes            String[]   @default([])
  resolution       String?
  falsePositive    Boolean    @default(false)
  appealMarker     String?
  resolvedByUserId String?
  resolvedAt       DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([status, priority, updatedAt])
  @@index([userId, updatedAt])
  @@index([matchId, updatedAt])
  @@index([roomId, updatedAt])
  @@index([matchMode, updatedAt])
  @@index([falsePositive, updatedAt])
}

model PlayerReport {
  id                      String     @id @default(cuid())
  status                  String     @default("open")
  reason                  String
  details                 String?
  reporterUserId          String
  reporterPlayerSessionId String
  reporterName            String
  targetUserId            String
  targetPlayerSessionId   String
  targetName              String
  targetTeam              String?
  roomId                  String
  matchId                 String?
  lobbyId                 String?
  matchMode               MatchMode?
  mapSeed                 Int?
  serverTick              Int        @default(0)
  evidenceEventId         String?
  metadata                Json       @default("{}")
  resolvedByUserId        String?
  resolvedAt              DateTime?
  resolution              String?
  actionType              String?
  accountActionId         String?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  @@index([status, updatedAt])
  @@index([targetUserId, createdAt])
  @@index([reporterUserId, createdAt])
  @@index([roomId, createdAt])
  @@index([matchId, createdAt])
  @@index([resolvedByUserId, resolvedAt])
}
