// Prisma schema for Slop Heroes
// PostgreSQL database for user persistence

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  discord
  wallet
}

enum MatchMode {
  quick_play
  ranked
  custom
  custom_wager
}

enum WageredLobbyStatus {
  waiting
  locked
  in_game
  review_required
  settling
  settled
  refunding
  refunded
  failed
}

enum WagerPaymentStatus {
  intent_created
  submitted
  confirmed
  credited
  refunding
  refunded
  settled
  failed
  expired
}

enum WagerSettlementStatus {
  pending
  processing
  complete
  failed
}

enum WagerSettlementTransferKind {
  winner_payout
  treasury_fee
  burn
  refund
}

enum WagerSettlementTransferStatus {
  pending
  submitted
  confirmed
  failed
}

enum GoldenBiomeRewardStatus {
  pending
  processing
  complete
  failed
}

enum GoldenBiomeRewardTransferStatus {
  pending
  submitted
  confirmed
  failed
}

enum GoldenBiomeRewardDistributionMode {
  manual
  auto
}

enum PlayerRewardKind {
  daily_ranked_drip
  objective_bounty
  season_top_10
  daily_mission
  ranked_br_combat_bounty
}

enum PlayerRewardStatus {
  pending
  processing
  paid
  failed
  canceled
}

enum PlayerRewardPayoutStatus {
  pending
  submitted
  confirmed
  failed
}

enum RankedSeasonMode {
  preseason
  season
}

enum RankedEntryGateMode {
  locked
  token_required
}

enum FriendshipStatus {
  pending
  accepted
  declined
  canceled
}

enum LobbyInviteStatus {
  pending
  accepted
  declined
  canceled
  expired
}

enum PartyInviteStatus {
  pending
  accepted
  declined
  canceled
  expired
}

enum SkinEntitlementSource {
  free
  paid
  admin_grant
  event
}

enum SkinPurchaseIntentStatus {
  intent_created
  transaction_built
  submitted
  confirmed
  credited
  failed
  expired
}

enum MissionRewardType {
  sol
  game_token
  skin
}

enum MissionRewardGrantStatus {
  pending
  processing
  granted
  failed
  canceled
}

enum GameTokenPayoutStatus {
  pending
  processing
  submitted
  granted
  failed
  canceled
}

model User {
  id                     String                  @id @default(cuid())
  walletAddress          String?                 @unique
  // Callsigns are unique case-insensitively via the User_name_lower_key index.
  name                   String                  @unique
  lastLoginAt            DateTime?
  tutorialCompletedAt    DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  authAccounts           AuthAccount[]
  matchStats             GameMatchParticipant[]
  wageredLobbies         WageredLobby[]
  wagerPayments          WagerPayment[]
  rankedEntryQuotes      RankedEntryQuote[]
  rankedSeasonStats      RankedSeasonUserStats[]
  friendshipsA           Friendship[]            @relation("FriendshipUserA")
  friendshipsB           Friendship[]            @relation("FriendshipUserB")
  friendshipRequestsSent Friendship[]            @relation("FriendshipRequester")
  sentLobbyInvites       LobbyInvite[]           @relation("LobbyInviteSender")
  receivedLobbyInvites   LobbyInvite[]           @relation("LobbyInviteRecipient")
  sentPartyInvites       PartyInvite[]           @relation("PartyInviteSender")
  receivedPartyInvites   PartyInvite[]           @relation("PartyInviteRecipient")
  skinOwnerships         UserSkinOwnership[]
  skinPurchaseIntents    SkinPurchaseIntent[]
  heroLoadouts           UserHeroLoadout[]
  playerRewards          PlayerReward[]
  playerRewardPayouts    PlayerRewardPayout[]
  dailyMissionProgress   UserDailyMissionProgress[]
  dailyMissionContributions UserDailyMissionContribution[]
  missionRewardGrants    MissionRewardGrant[]
  gameTokenPayouts       GameTokenPayout[]

  // Player stats (optional - can expand later)
  totalGames                Int       @default(0)
  totalWins                 Int       @default(0)
  totalLosses               Int       @default(0)
  totalDraws                Int       @default(0)
  totalKills                Int       @default(0)
  totalDeaths               Int       @default(0)
  totalAssists              Int       @default(0)
  totalCaptures             Int       @default(0)
  totalFlagReturns          Int       @default(0)
  totalScore                Int       @default(0)
  totalExperience           Int       @default(0)
  totalWagerGames           Int       @default(0)
  totalWagerWins            Int       @default(0)
  totalWagerLosses          Int       @default(0)
  totalWagerDraws           Int       @default(0)
  totalWageredLamports      BigInt    @default(0)
  totalWagerWonLamports     BigInt    @default(0)
  totalWagerLostLamports    BigInt    @default(0)
  competitiveRating         Int       @default(800)
  rankedGames               Int       @default(0)
  rankedWins                Int       @default(0)
  rankedLosses              Int       @default(0)
  rankedDraws               Int       @default(0)
  rankedPlacementsRemaining Int       @default(0)
  rankedPeakRating          Int       @default(800)
  rankedLastMatchAt         DateTime?

  @@index([walletAddress])
  @@index([competitiveRating(sort: Desc), rankedWins(sort: Desc), rankedGames, createdAt])
}

model AuthAccount {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  displayName       String?
  avatarUrl         String?
  emailHash         String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Friendship {
  id                String           @id @default(cuid())
  userAId           String
  userBId           String
  requestedByUserId String
  status            FriendshipStatus @default(pending)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  respondedAt       DateTime?

  userA       User @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB       User @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)
  requestedBy User @relation("FriendshipRequester", fields: [requestedByUserId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId, status])
  @@index([userBId, status])
  @@index([requestedByUserId, status])
  @@index([status, updatedAt])
}

model LobbyInvite {
  id          String            @id @default(cuid())
  lobbyId     String
  lobbyName   String
  matchMode   MatchMode?
  fromUserId  String
  toUserId    String
  status      LobbyInviteStatus @default(pending)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  expiresAt   DateTime
  respondedAt DateTime?

  fromUser User @relation("LobbyInviteSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("LobbyInviteRecipient", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId, status, createdAt])
  @@index([fromUserId, createdAt])
  @@index([lobbyId, status])
  @@index([expiresAt])
}

model PartyInvite {
  id          String            @id @default(cuid())
  partyId     String
  fromUserId  String
  toUserId    String
  status      PartyInviteStatus @default(pending)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  expiresAt   DateTime
  respondedAt DateTime?

  fromUser User @relation("PartyInviteSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("PartyInviteRecipient", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId, status, createdAt])
  @@index([fromUserId, createdAt])
  @@index([partyId, status])
  @@index([expiresAt])
}

model SkinShopSettings {
  id              String   @id @default("default")
  enabled         Boolean  @default(false)
  tokenMintAddress String?
  tokenSymbol     String   @default("")
  cluster         String   @default("devnet")
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SkinShopItemSettings {
  skinId               String   @id
  saleEnabled          Boolean  @default(false)
  tokenAmountBaseUnits BigInt?
  maxSupply            Int?
  priceVersion         Int      @default(1)
  updatedByUserId      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  audits               SkinShopItemAudit[]
}

model SkinShopItemAudit {
  id                         String   @id @default(cuid())
  skinId                     String
  updatedByUserId            String?
  oldTokenAmountBaseUnits    BigInt?
  newTokenAmountBaseUnits    BigInt?
  oldMaxSupply               Int?
  newMaxSupply               Int?
  oldSaleEnabled             Boolean?
  newSaleEnabled             Boolean?
  oldPriceVersion            Int?
  newPriceVersion            Int?
  createdAt                  DateTime @default(now())

  item SkinShopItemSettings @relation(fields: [skinId], references: [skinId], onDelete: Cascade)

  @@index([skinId, createdAt])
  @@index([updatedByUserId, createdAt])
}

model UserSkinOwnership {
  id         String                @id @default(cuid())
  userId     String
  skinId     String
  source     SkinEntitlementSource
  purchaseId String?               @unique
  grantedAt  DateTime              @default(now())
  revokedAt  DateTime?

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchase SkinPurchaseIntent? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@unique([userId, skinId])
  @@index([userId, revokedAt])
  @@index([skinId, grantedAt])
}

model SkinPurchaseIntent {
  id                   String                   @id @default(cuid())
  userId               String
  walletAddress        String
  skinId               String
  quotedPriceVersion   Int
  tokenMintAddress     String
  tokenSymbol          String
  tokenAmountBaseUnits BigInt
  tokenDecimals        Int?
  treasuryWallet       String
  treasuryTokenAccount String
  cluster              String
  memo                 String                   @unique
  status               SkinPurchaseIntentStatus @default(intent_created)
  transactionSignature String?                  @unique
  intentExpiresAt      DateTime
  lastValidBlockHeight BigInt?
  creditedAt           DateTime?
  lastError            String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownership UserSkinOwnership?

  @@index([userId, status, createdAt])
  @@index([walletAddress])
  @@index([skinId, status])
  @@index([status, intentExpiresAt])
}

model UserHeroLoadout {
  id             String   @id @default(cuid())
  userId         String
  heroId         String
  selectedSkinId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, heroId])
  @@index([userId])
  @@index([selectedSkinId])
}

// Singleton counter backing the "first 50 ranked BR winners" golden founder reward.
// Claimed via an atomic conditional increment so concurrent match finalizations
// can never grant more than maxClaims founder sets.
model RankedFounderReward {
  id           String   @id @default("ranked_founder_golden")
  claimedCount Int      @default(0)
  maxClaims    Int      @default(50)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PersistentParty {
  id             String   @id
  roomId         String   @unique
  ownerUserId    String
  leaderUserId   String?
  allowedUserIds String[] @default([])
  snapshot       Json
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([ownerUserId, updatedAt])
  @@index([expiresAt])
}

model GameMatch {
  id                       String    @id
  roomId                   String
  lobbyId                  String?
  matchMode                MatchMode @default(custom)
  gameplayMode             String    @default("capture_the_flag")
  mapSeed                  BigInt
  mapThemeId               String    @default("standard")
  mapSize                  String?
  mapProfileId             String?
  mapTopologyId            String?
  mapGeneratorVersion      Int?
  pregeneratedMapId        String?
  startedAt                DateTime
  endedAt                  DateTime
  redScore                 Int
  blueScore                Int
  winningTeam              String?
  rankedEligible           Boolean   @default(false)
  rankedSeasonMode         RankedSeasonMode?
  rankedSeasonNumber       Int?
  antiCheatIntegrityStatus String    @default("clean")
  antiCheatReviewRequired  Boolean   @default(false)
  antiCheatIntegrityReason String?
  rankedOutcomeStatus      String    @default("not_applicable")
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  participants GameMatchParticipant[]
  playerRewards PlayerReward[]
  killEvents GameMatchKillEvent[]
  pregeneratedMap PregeneratedMap? @relation(fields: [pregeneratedMapId], references: [id], onDelete: SetNull)

  @@index([roomId])
  @@index([lobbyId])
  @@index([matchMode])
  @@index([gameplayMode])
  @@index([mapThemeId])
  @@index([mapSize])
  @@index([mapProfileId])
  @@index([mapTopologyId])
  @@index([pregeneratedMapId])
  @@index([startedAt])
  @@index([winningTeam])
  @@index([rankedEligible])
  @@index([rankedSeasonMode, rankedSeasonNumber])
  @@index([antiCheatIntegrityStatus])
  @@index([antiCheatReviewRequired])
  @@index([rankedOutcomeStatus])
}

model PregeneratedMapArtifact {
  id                    String   @id
  storageProvider       String   @default("database")
  storageKey            String   @unique
  byteSize              Int
  compressionCodec      String   @default("none")
  contentHash           String   @unique
  manifestSchemaVersion Int
  data                  Bytes?
  createdAt             DateTime @default(now())

  maps PregeneratedMap[]

  @@index([storageProvider])
  @@index([contentHash])
  @@index([createdAt])
}

model PregeneratedMap {
  id                  String   @id
  artifactId          String
  generatorVersion    Int
  seed                BigInt
  themeId             String
  profileId           String
  gameplayMode        String
  familyId            String
  mapSize             String
  topologyId          String
  displayName         String
  previewTags         String[] @default([])
  previewSilhouette   Json
  stats               Json
  diagnosticsScore    Float
  diagnosticsWarnings String[] @default([])
  status              String   @default("ready")
  visibility          String   @default("public")
  lastSelectedAt      DateTime?
  selectionCount      Int      @default(0)
  failureCount        Int      @default(0)
  reservationExpiresAt DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  artifact   PregeneratedMapArtifact @relation(fields: [artifactId], references: [id], onDelete: Restrict)
  selections PregeneratedMapSelection[]
  matches    GameMatch[]

  @@unique([seed, themeId, profileId, mapSize, topologyId, generatorVersion, visibility])
  @@index([artifactId])
  @@index([status, visibility, gameplayMode, profileId, mapSize, themeId, topologyId])
  @@index([gameplayMode, profileId, mapSize, status, visibility, lastSelectedAt])
  @@index([generatorVersion, status])
  @@index([lastSelectedAt])
  @@index([createdAt])
}

model PregeneratedMapSelection {
  id                 String   @id @default(cuid())
  mapId              String
  lobbyId            String?
  roomId             String?
  matchId            String?
  selectionSource    String
  selectedByPlayerId String?
  selectedAt         DateTime @default(now())

  map PregeneratedMap @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@index([mapId, selectedAt])
  @@index([lobbyId])
  @@index([roomId])
  @@index([matchId])
  @@index([selectionSource, selectedAt])
}

model GameMatchKillEvent {
  id                    String   @id @default(cuid())
  matchId               String
  killerUserId          String?
  killerPlayerSessionId String?
  victimUserId          String?
  victimPlayerSessionId String
  killerHeroId          String?
  victimHeroId          String?
  abilityId             String?
  damageType            String?
  victimHadFlag         Boolean  @default(false)
  occurredAt            DateTime
  createdAt             DateTime @default(now())

  match GameMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, occurredAt])
  @@index([killerUserId, occurredAt])
  @@index([victimUserId, occurredAt])
  @@index([killerHeroId, occurredAt])
  @@index([victimHeroId, occurredAt])
  @@index([abilityId, occurredAt])
  @@index([victimHadFlag, occurredAt])
}

model GameMatchParticipant {
  id                   String    @id @default(cuid())
  matchId              String
  userId               String
  playerSessionId      String
  displayName          String
  team                 String
  heroId               String?
  kills                Int       @default(0)
  deaths               Int       @default(0)
  assists              Int       @default(0)
  flagCaptures         Int       @default(0)
  flagReturns          Int       @default(0)
  score                Int       @default(0)
  experienceGained     Int       @default(0)
  outcome              String
  placement            Int?
  rankedEligible       Boolean   @default(false)
  ratingBefore         Int?
  ratingAfter          Int?
  ratingDelta          Int?
  visibleRankBefore    String?
  visibleRankAfter     String?
  rankedPlacementPoints Int?
  rankedCombatPoints   Int?
  rankedEntryCost      Int?
  rankedQualityMultiplier Float?
  rankedRulesVersion   String?
  rankedBreakdown      Json?
  leaverPenaltyApplied Boolean   @default(false)
  joinedAt             DateTime
  leftAt               DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  match GameMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([matchId])
  @@index([userId, joinedAt])
  @@index([outcome])
  @@index([rankedEligible])
  @@index([userId, rankedEligible, joinedAt])
}

model RankedEntryQuote {
  id                  String   @id @default(cuid())
  userId              String
  usdCents            Int
  solUsdPriceMicroUsd BigInt
  coverChargeLamports BigInt
  priceSource         String
  cluster             String
  createdAt           DateTime @default(now())
  expiresAt           DateTime

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  wageredLobbies WageredLobby[]
  wagerPayments  WagerPayment[]

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@index([coverChargeLamports])
}

model WageredLobby {
  id                  String             @id @default(cuid())
  lobbyId             String             @unique
  gameRoomId          String?
  matchId             String?
  matchMode           MatchMode          @default(custom_wager)
  rankedEntryQuoteId  String?
  status              WageredLobbyStatus @default(waiting)
  token               String             @default("SOL")
  coverChargeLamports BigInt
  treasuryWallet      String
  createdByUserId     String
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  lockedAt            DateTime?
  settledAt           DateTime?

  createdBy        User              @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  rankedEntryQuote RankedEntryQuote? @relation(fields: [rankedEntryQuoteId], references: [id], onDelete: SetNull)
  payments         WagerPayment[]
  settlement       WagerSettlement?

  @@index([lobbyId])
  @@index([matchMode])
  @@index([rankedEntryQuoteId])
  @@index([gameRoomId])
  @@index([matchId])
  @@index([status])
  @@index([createdByUserId])
}

model WagerPayment {
  id                        String             @id
  wageredLobbyId            String
  lobbyPlayerId             String?
  userId                    String
  walletAddress             String
  rankedEntryQuoteId        String?
  teamAtLock                String?
  amountLamports            BigInt
  surplusLamports           BigInt             @default(0)
  memo                      String             @unique
  intentExpiresAt           DateTime
  status                    WagerPaymentStatus @default(intent_created)
  depositSignature          String?            @unique
  refundSignature           String?            @unique
  refundReason              String?
  refundGrossLamports       BigInt?
  refundOutboundFeeLamports BigInt?
  refundNetLamports         BigInt?
  refundFeeSource           String?
  lastError                 String?
  creditedAt                DateTime?
  refundedAt                DateTime?
  settledAt                 DateTime?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  wageredLobby     WageredLobby      @relation(fields: [wageredLobbyId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  rankedEntryQuote RankedEntryQuote? @relation(fields: [rankedEntryQuoteId], references: [id], onDelete: SetNull)

  @@unique([wageredLobbyId, userId])
  @@index([wageredLobbyId])
  @@index([userId])
  @@index([rankedEntryQuoteId])
  @@index([walletAddress])
  @@index([status])
  @@index([intentExpiresAt])
}

model WagerSettlement {
  id                   String                @id @default(cuid())
  wageredLobbyId       String                @unique
  matchId              String?
  winningTeam          String?
  totalPotLamports     BigInt                @default(0)
  treasuryFeeLamports  BigInt                @default(0)
  burnLamports         BigInt                @default(0)
  winnerPoolLamports   BigInt                @default(0)
  status               WagerSettlementStatus @default(pending)
  attemptCount         Int                   @default(0)
  lastError            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  completedAt          DateTime?

  wageredLobby WageredLobby              @relation(fields: [wageredLobbyId], references: [id], onDelete: Cascade)
  transfers    WagerSettlementTransfer[]

  @@index([matchId])
  @@index([status])
}

model WagerSettlementTransfer {
  id                        String                        @id @default(cuid())
  settlementId              String
  idempotencyKey            String                        @unique
  kind                      WagerSettlementTransferKind
  recipientWallet           String
  amountLamports            BigInt
  tokenMintAddress          String?
  tokenProgramId            String?
  tokenDecimals             Int?
  tokenAccountAddress       String?
  convertedTokenBaseUnits   BigInt?
  conversionSignature       String?                       @unique
  burnSignature             String?                       @unique
  signature                 String?                       @unique
  refundReason              String?
  refundGrossLamports       BigInt?
  refundOutboundFeeLamports BigInt?
  refundNetLamports         BigInt?
  refundFeeSource           String?
  status                    WagerSettlementTransferStatus @default(pending)
  lastError                 String?
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt
  confirmedAt               DateTime?

  settlement WagerSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@unique([settlementId, kind, recipientWallet])
  @@index([settlementId])
  @@index([kind])
  @@index([status])
}

model GoldenBiomeReward {
  id                      String                            @id @default(cuid())
  matchId                 String                            @unique
  roomId                  String
  lobbyId                 String?
  mapSeed                 BigInt
  mapThemeId              String                            @default("golden")
  winningTeam             String
  treasuryWallet          String
  rewardUsdCents          Int
  solUsdPriceMicroUsd     BigInt
  rewardLamports          BigInt
  totalRewardLamports     BigInt
  paidPlayerCount         Int
  treasuryBalanceLamports BigInt
  status                  GoldenBiomeRewardStatus           @default(pending)
  distributionMode        GoldenBiomeRewardDistributionMode @default(manual)
  distributedByUserId     String?
  distributedAt           DateTime?
  attemptCount            Int                               @default(0)
  lastError               String?
  createdAt               DateTime                          @default(now())
  updatedAt               DateTime                          @updatedAt
  completedAt             DateTime?

  transfers GoldenBiomeRewardTransfer[]

  @@index([roomId])
  @@index([lobbyId])
  @@index([status])
  @@index([distributionMode])
  @@index([createdAt])
}

model GoldenBiomeRewardSettings {
  id                    String                            @id @default("default")
  distributionMode      GoldenBiomeRewardDistributionMode @default(manual)
  enabled               Boolean                           @default(true)
  chanceBps             Int                               @default(200)
  winnerRewardLamports  BigInt                            @default(200000000)
  treasuryMinLamports   BigInt                            @default(1000000000)
  updatedByUserId       String?
  createdAt             DateTime                          @default(now())
  updatedAt             DateTime                          @updatedAt
}

model PlayerRewardSettings {
  id                          String   @id @default("default")
  enabled                     Boolean  @default(true)
  settingsVersion             Int      @default(1)
  dailyRankedDripLamports     BigInt   @default(20000)
  dailyRankedDripMaxMatches   Int      @default(5)
  minMatchDurationMs          Int      @default(180000)
  objectiveWinLamports        BigInt   @default(10000)
  objectiveFlagCaptureLamports BigInt  @default(15000)
  objectiveFlagReturnLamports BigInt   @default(5000)
  objectiveAssistLamports     BigInt   @default(2000)
  maxPlayerMatchLamports      BigInt   @default(50000)
  maxMatchPayoutLamports      BigInt   @default(250000)
  treasuryReserveLamports     BigInt   @default(0)
  payoutBatchSize             Int      @default(100)
  rankedBrCombatRewardsEnabled Boolean @default(true)
  rankedBrCombatRewardsShadowMode Boolean @default(false)
  rankedBrDamageLamportsPerHp BigInt   @default(250)
  rankedBrKillLamports        BigInt   @default(100000)
  rankedBrBotTargetRewardBps  Int      @default(7000)
  rankedBrSourceVictimDamageCapHp Int   @default(315)
  rankedBrMaxPlayerMatchLamports BigInt @default(750000)
  rankedBrMaxPlayerDailyLamports BigInt @default(2500000)
  rankedBrMaxMatchLamports    BigInt   @default(5000000)
  rankedBrTreasuryExposureBps Int      @default(10000)
  rankedBrClientRewardTextMinLamports BigInt @default(1000)
  minPayoutUsdCents           Int      @default(1500)
  payoutPriceQuoteTtlMs       Int      @default(300000)
  updatedByUserId             String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

// Temporary event biome toggle (e.g. the 4th-of-July "Independence Day" map theme).
// When enabled, one of the three CTF/TDM map-vote options is forced to use `themeId`.
model EventBiomeSettings {
  id              String   @id @default("default")
  enabled         Boolean  @default(false)
  themeId         String   @default("independence")
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PlayerReward {
  id              String             @id @default(cuid())
  userId          String
  matchId         String?
  playerSessionId String?
  kind            PlayerRewardKind
  status          PlayerRewardStatus @default(pending)
  amountLamports  BigInt
  idempotencyKey  String             @unique
  reason          String
  metadata        Json?
  payoutId        String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  paidAt          DateTime?

  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  match                GameMatch?           @relation(fields: [matchId], references: [id], onDelete: SetNull)
  payout               PlayerRewardPayout?  @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  missionRewardGrants  MissionRewardGrant[]

  @@index([userId, status, createdAt])
  @@index([kind, createdAt])
  @@index([matchId])
  @@index([payoutId])
  @@index([status, createdAt])
}

model DailyMissionDefinition {
  id              String   @id @default(cuid())
  displayName     String
  description     String   @default("")
  enabled         Boolean  @default(true)
  sortOrder       Int      @default(0)
  activeStartsAt  DateTime?
  activeEndsAt    DateTime?
  resetPolicy     String   @default("utc")
  criteria        Json
  rewards         Json
  eligibility     Json
  createdByUserId String?
  updatedByUserId String?
  archivedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  progress      UserDailyMissionProgress[]
  contributions UserDailyMissionContribution[]
  rewardGrants  MissionRewardGrant[]

  @@index([enabled, archivedAt, sortOrder])
  @@index([activeStartsAt, activeEndsAt])
  @@index([archivedAt, updatedAt])
}

model UserDailyMissionProgress {
  id                 String    @id @default(cuid())
  userId             String
  missionId          String
  dayKey             String
  progress           Json
  completedAt        DateTime?
  grantedAt          DateTime?
  lastContributingMatchId String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user    User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission DailyMissionDefinition @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId, dayKey])
  @@index([userId, dayKey])
  @@index([missionId, dayKey])
  @@index([completedAt])
  @@index([grantedAt])
}

model UserDailyMissionContribution {
  id        String   @id @default(cuid())
  userId    String
  missionId String
  dayKey    String
  matchId   String
  createdAt DateTime @default(now())

  user    User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission DailyMissionDefinition @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId, dayKey, matchId])
  @@index([matchId])
  @@index([missionId, dayKey])
}

model MissionRewardGrant {
  id              String                   @id @default(cuid())
  userId          String
  missionId       String
  dayKey          String
  rewardType      MissionRewardType
  amountBaseUnits BigInt?
  skinId          String?
  status          MissionRewardGrantStatus @default(pending)
  idempotencyKey  String                   @unique
  playerRewardId  String?
  tokenPayoutId   String?                  @unique
  metadata        Json?
  lastError       String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  grantedAt       DateTime?

  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission      DailyMissionDefinition @relation(fields: [missionId], references: [id], onDelete: Cascade)
  playerReward PlayerReward?          @relation(fields: [playerRewardId], references: [id], onDelete: SetNull)
  tokenPayout  GameTokenPayout?       @relation(fields: [tokenPayoutId], references: [id], onDelete: SetNull)

  @@index([userId, dayKey])
  @@index([missionId, dayKey])
  @@index([rewardType, status])
  @@index([status, createdAt])
}

model GameTokenPayout {
  id                   String                @id @default(cuid())
  userId               String
  walletAddress        String?
  tokenMintAddress     String
  tokenSymbol          String
  tokenAmountBaseUnits BigInt
  tokenDecimals        Int?
  treasuryTokenAccount String?
  recipientTokenAccount String?
  status               GameTokenPayoutStatus @default(pending)
  signature            String?               @unique
  idempotencyKey       String                @unique
  attemptCount         Int                   @default(0)
  lastError            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  submittedAt          DateTime?
  grantedAt            DateTime?
  failedAt             DateTime?

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  missionRewardGrant  MissionRewardGrant?

  @@index([userId, status, createdAt])
  @@index([status, createdAt])
  @@index([tokenMintAddress])
}

model PlayerRewardPayout {
  id             String                  @id @default(cuid())
  userId         String
  walletAddress  String
  amountLamports BigInt
  status         PlayerRewardPayoutStatus @default(pending)
  signature      String?                 @unique
  priceSource    String?
  solUsdPriceMicroUsd BigInt?
  priceObservedAt DateTime?
  lastError      String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  submittedAt    DateTime?
  confirmedAt    DateTime?
  failedAt       DateTime?

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewards PlayerReward[]

  @@index([userId, status, createdAt])
  @@index([walletAddress])
  @@index([status, createdAt])
}

model RankedSeasonSettings {
  id              String           @id @default("default")
  mode            RankedSeasonMode @default(season)
  seasonNumber    Int              @default(1)
  endsAt          DateTime?
  lastResetAt     DateTime?
  updatedByUserId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model RankedEntryGateSettings {
  id                     String              @id @default("default")
  mode                   RankedEntryGateMode @default(locked)
  tokenMintAddress       String?
  tokenSymbol            String              @default("")
  requiredTokenAmount    String              @default("0")
  updatedByUserId        String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
}

model RankedSeasonUserStats {
  id                        String           @id @default(cuid())
  mode                      RankedSeasonMode @default(season)
  seasonNumber              Int
  userId                    String
  userName                  String
  totalGames                Int              @default(0)
  totalWins                 Int              @default(0)
  totalLosses               Int              @default(0)
  totalDraws                Int              @default(0)
  totalKills                Int              @default(0)
  totalDeaths               Int              @default(0)
  totalAssists              Int              @default(0)
  totalCaptures             Int              @default(0)
  totalFlagReturns          Int              @default(0)
  totalScore                Int              @default(0)
  totalExperience           Int              @default(0)
  competitiveRating         Int              @default(800)
  rankedGames               Int              @default(0)
  rankedWins                Int              @default(0)
  rankedLosses              Int              @default(0)
  rankedDraws               Int              @default(0)
  rankedPlacementsRemaining Int              @default(0)
  rankedPeakRating          Int              @default(800)
  rankedLastMatchAt         DateTime?
  archivedAt                DateTime?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mode, seasonNumber, userId])
  @@index([mode, seasonNumber, competitiveRating(sort: Desc), rankedWins(sort: Desc), rankedGames, updatedAt])
  @@index([userId, mode, seasonNumber])
}

model GlobalNotification {
  id              String   @id @default("active")
  message         String   @db.Text
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GlobalChatMessage {
  id         String   @id @default(cuid())
  userId     String?
  playerName String
  message    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt])
}

model GoldenBiomeRewardTransfer {
  id              String                          @id @default(cuid())
  rewardId        String
  idempotencyKey  String                          @unique
  userId          String
  playerSessionId String
  recipientWallet String
  amountLamports  BigInt
  signature       String?                         @unique
  status          GoldenBiomeRewardTransferStatus @default(pending)
  lastError       String?
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @updatedAt
  confirmedAt     DateTime?

  reward GoldenBiomeReward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@unique([rewardId, recipientWallet])
  @@index([rewardId])
  @@index([userId])
  @@index([recipientWallet])
  @@index([status])
}

model AntiCheatSignal {
  id               String     @id @default(cuid())
  eventId          String     @unique
  eventType        String
  category         String
  source           String
  roomId           String
  matchId          String?
  lobbyId          String?
  matchMode        MatchMode?
  userId           String?
  playerSessionId  String?
  team             String?
  heroId           String?
  serverTick       Int
  serverTime       BigInt
  movementEpoch    Int?
  movementSequence Int?
  severity         String
  confidence       Float
  reason           String?
  details          Json
  detailBytes      Int
  retentionClass   String
  scoreDelta       Int        @default(0)
  observedAt       DateTime
  createdAt        DateTime   @default(now())

  @@index([eventType, observedAt])
  @@index([category, severity, observedAt])
  @@index([roomId, observedAt])
  @@index([matchId, observedAt])
  @@index([lobbyId, observedAt])
  @@index([userId, observedAt])
  @@index([playerSessionId, observedAt])
  @@index([retentionClass, observedAt])
}

model AntiCheatPlayerProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  currentScore Int       @default(0)
  maxScore     Int       @default(0)
  scoreBand    String    @default("normal_noise")
  reviewFlags  String[]  @default([])
  lastSignalAt DateTime?
  lastScoredAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([currentScore])
  @@index([scoreBand])
  @@index([lastSignalAt])
}

model AntiCheatMatchIntegrity {
  id               String    @id @default(cuid())
  matchId          String    @unique
  roomId           String
  lobbyId          String?
  matchMode        MatchMode
  status           String    @default("clean")
  reason           String?
  score            Int       @default(0)
  affectedUserIds  String[]  @default([])
  affectedTeams    String[]  @default([])
  rankedImpact     String    @default("none")
  wagerImpact      String    @default("none")
  caseId           String?
  resolvedByUserId String?
  resolvedAt       DateTime?
  resolution       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([roomId])
  @@index([lobbyId])
  @@index([matchMode, status])
  @@index([caseId])
}

model AntiCheatPayoutHold {
  id               String    @id @default(cuid())
  wageredLobbyId   String    @unique
  matchId          String?
  winningTeam      String?
  paymentIds       String[]  @default([])
  affectedUserIds  String[]  @default([])
  amountLamports   BigInt    @default(0)
  reason           String
  status           String    @default("open")
  caseId           String?
  resolvedByUserId String?
  resolvedAt       DateTime?
  resolution       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([matchId])
  @@index([status, createdAt])
  @@index([caseId])
}

model AntiCheatAction {
  id                 String   @id @default(cuid())
  actionType         String
  roomId             String?
  matchId            String?
  caseId             String?
  userId             String?
  actorUserId        String?
  reason             String
  details            Json
  observedOnly       Boolean  @default(false)
  evidenceEventIds   String[] @default([])
  reversedByActionId String?
  createdAt          DateTime @default(now())

  @@index([actionType, createdAt])
  @@index([matchId, createdAt])
  @@index([caseId, createdAt])
  @@index([userId, createdAt])
  @@index([actorUserId, createdAt])
}

model AntiCheatAccountAction {
  id               String    @id @default(cuid())
  actionType       String
  targetUserId     String
  actorUserId      String
  reason           String
  evidenceCaseId   String?
  evidenceEventIds String[]  @default([])
  expiresAt        DateTime?
  liftedAt         DateTime?
  immutableAudit   Boolean   @default(false)
  createdAt        DateTime  @default(now())

  @@index([targetUserId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([actionType, createdAt])
  @@index([evidenceCaseId])
  @@index([expiresAt])
}

model AntiCheatCase {
  id               String     @id @default(cuid())
  userId           String?
  playerSessionId  String?
  matchId          String?
  roomId           String?
  lobbyId          String?
  matchMode        MatchMode?
  status           String     @default("open")
  priority         String     @default("medium")
  reason           String
  scoreAtOpen      Int        @default(0)
  signalCount      Int        @default(0)
  evidenceEventIds String[]   @default([])
  assignedToUserId String?
  notes            String[]   @default([])
  resolution       String?
  falsePositive    Boolean    @default(false)
  appealMarker     String?
  resolvedByUserId String?
  resolvedAt       DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([status, priority, updatedAt])
  @@index([userId, updatedAt])
  @@index([matchId, updatedAt])
  @@index([roomId, updatedAt])
  @@index([matchMode, updatedAt])
  @@index([falsePositive, updatedAt])
}

model PlayerReport {
  id                      String     @id @default(cuid())
  status                  String     @default("open")
  reason                  String
  details                 String?
  reporterUserId          String
  reporterPlayerSessionId String
  reporterName            String
  targetUserId            String
  targetPlayerSessionId   String
  targetName              String
  targetTeam              String?
  roomId                  String
  matchId                 String?
  lobbyId                 String?
  matchMode               MatchMode?
  mapSeed                 BigInt?
  serverTick              Int        @default(0)
  evidenceEventId         String?
  metadata                Json       @default("{}")
  resolvedByUserId        String?
  resolvedAt              DateTime?
  resolution              String?
  actionType              String?
  accountActionId         String?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  @@index([status, updatedAt])
  @@index([targetUserId, createdAt])
  @@index([reporterUserId, createdAt])
  @@index([roomId, createdAt])
  @@index([matchId, createdAt])
  @@index([resolvedByUserId, resolvedAt])
}
