# GENERAL
ENABLE_DEV_TOOLS=true
CLIENT_ORIGIN="http://localhost:3000"
PORT=2567
JWT_SECRET="voxel-strike-local-dev-secret"

# COLYSEUS DISTRIBUTED RUNTIME
COLYSEUS_DISTRIBUTED=0
COLYSEUS_REDIS_URL="redis://localhost:6379"
COLYSEUS_ROUTING_STRATEGY="direct"
COLYSEUS_PUBLIC_ADDRESS="localhost:2567"
COLYSEUS_REQUIRE_PUBLIC_ADDRESS=0
# Fly multi-machine production:
# COLYSEUS_DISTRIBUTED=1
# COLYSEUS_REDIS_URL="<Fly managed Upstash Redis private URL>"
# COLYSEUS_ROUTING_STRATEGY="fly_replay"
# COLYSEUS_PUBLIC_ADDRESS="opus-strike-server.fly.dev"
# COLYSEUS_REQUIRE_PUBLIC_ADDRESS=1
# FLY_APP_NAME, FLY_MACHINE_ID, and FLY_REGION are provided by Fly.
# Optional:
# COLYSEUS_FLY_PROCESS_REGISTRY_TTL_MS=30000
# COLYSEUS_FLY_PROCESS_REGISTRY_HEARTBEAT_MS=10000
# COLYSEUS_FLY_REPLAY_TIMEOUT="5s"
# COLYSEUS_FLY_REPLAY_FALLBACK="force_self"

# DATABASE
DATABASE_URL="postgresql://voxelstrike:voxelstrike_dev@localhost:55433/voxelstrike?schema=public"

# DISCORD AUTHENTICATION
DISCORD_AUTH_ENABLED="true"
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_REDIRECT_URI="http://localhost:2567/auth/discord/callback"
DISCORD_OAUTH_SCOPES="identify"


# SOLANA
WAGER_SOL_ENABLED="false"
SOLANA_CLUSTER="mainnet-beta"
SOLANA_RPC_URL="https://solana-mainnet.g.alchemy.com/v2/YOUR_KEY"
WAGER_TREASURY_WALLET=""
WAGER_SETTLEMENT_SECRET_KEY=""
WAGER_MIN_COVER_CHARGE_LAMPORTS="1000000"
WAGER_MAX_COVER_CHARGE_LAMPORTS="10000000000"
WAGER_PLATFORM_FEE_BPS="500"
WAGER_ADMIN_TOKEN="a-long-random-admin-only-secret"
